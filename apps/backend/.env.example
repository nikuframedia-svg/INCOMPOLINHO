# PP1 Backend Environment Variables

# OpenAI API key for copilot (GPT-4o function calling)
PP1_OPENAI_API_KEY=sk-...
# Alternative: OPENAI_API_KEY=sk-...

# OpenAI model (default: gpt-4o)
# PP1_OPENAI_MODEL=gpt-4o

# Database URL (PostgreSQL)
# DATABASE_URL=postgresql://user:pass@localhost:5432/pp1

# CORS origins (comma-separated)
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174
